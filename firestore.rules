rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tickets/{ticketId} {
      // Anyone can read (for the public read-only view)
      allow read: if true;

      // Only the owner can write
      allow write: if request.auth != null && request.auth.token.email == "luismorenosofteng@gmail.com";
    }
  }
}
